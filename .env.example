# Copy this file to .env, then restart the dev server.

# --- Simplest for local dev: call Claude directly from the browser ---
# WARNING: this bundles your key into client JS. Local use only.
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Recommended for anything shared: backend proxy (key stays server-side) ---
# Start it with:  yarn proxy    (listens on :8787)
# Then set these instead of the direct key above:
# VITE_PROXY_URL=/api/messages
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the model (defaults to claude-sonnet-4-6)
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
